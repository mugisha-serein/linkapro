# Django Settings
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=False

# Database
# Production should set DATABASE_URL. Local development can use DATABASE_URL,
# the DB_* values below, or no database variables to use local SQLite.
DATABASE_URL=postgres://database-user:database-password@localhost:5432/database-name
DB_NAME=database-name
DB_USER=database-user
DB_PASSWORD=database-password
DB_HOST=localhost
DB_PORT=5432
ALLOWED_HOSTS=localhost,127.0.0.1
FASTAPI_DATABASE_URL=postgresql+asyncpg://linkapro_admin:password@localhost:5432/linkapro

TEST_DB_NAME=database-test-name
TEST_DB_USER=database-test-user
TEST_DB_PASSWORD=database-test-password
TEST_DB_HOST=localhost
TEST_DB_PORT=5432

# Redis
# Local Redis: redis://localhost:6379/0
# Production Redis/Upstash/Render may use rediss:// with TLS.
# Example: rediss://default:PASSWORD@HOST:PORT?ssl_cert_reqs=CERT_REQUIRED
REDIS_URL=redis://localhost:6379/0

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional ODCR/OCR document verification preflight
ODCR_ENABLED=false
ODCR_API_URL=
ODCR_API_KEY=
ODCR_TIMEOUT_SECONDS=10

# Optional professional media analyzer
VENDOR_PORTFOLIO_MAX_UPLOAD_SIZE=4194304
VENDOR_PORTFOLIO_MIN_IMAGE_WIDTH=800
VENDOR_PORTFOLIO_MIN_IMAGE_HEIGHT=600
MEDIA_ANALYZER_ENABLED=false
MEDIA_ANALYZER_API_URL=
MEDIA_ANALYZER_API_KEY=
MEDIA_ANALYZER_TIMEOUT_SECONDS=10

# Email / SendGrid SMTP
# Production must set SENDGRID_API_KEY, DEFAULT_FROM_EMAIL, and FRONTEND_URL.
SENDGRID_API_KEY=your-sendgrid-key
DEFAULT_FROM_EMAIL=no-reply@linkapro.rw
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=apikey

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Callback URL registered in Google Cloud Console (NOT the Google auth URL).
# Local: http://localhost:8000/api/django/identity/auth/google/callback/
GOOGLE_REDIRECT_URI=http://localhost:8000/api/django/identity/auth/google/callback/
FRONTEND_URL=http://localhost:3000
FASTAPI_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Browser client access
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Flutterwave
FLW_SECRET_KEY=your_flutterwave_secret_key
FLW_SECRET_HASH=your_webhook_secret_hash
PAYMENT_ENV=test

# Flutterwave Webhook Decryptor
FLW_ENCRYPTION_KEY=your_24_byte_3des_key_here

# reCAPTCHA
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# FastAPI Internal URL (for Celery tasks)
FASTAPI_INTERNAL_URL=http://localhost:8001
FASTAPI_INTERNAL_SHARED_SECRET=change-me
FASTAPI_ENV=development
FASTAPI_SCHEMA_BOOTSTRAP=true
FASTAPI_MARKETPLACE_SEARCH_CACHE_TTL_SECONDS=120
FASTAPI_MARKETPLACE_SEARCH_RATE_LIMIT_REQUESTS=60
FASTAPI_MARKETPLACE_SEARCH_RATE_LIMIT_WINDOW_SECONDS=60

# Vault
VAULT_ADDR=http://vault:8200
VAULT_ROLE_ID=your-role-id
VAULT_SECRET_ID=your-secret-id
VAULT_TRANSIT_KEY_NAME=linkapro-payments-kek

# HMAC Key Provider
PROVIDER_REFERENCE_HMAC_KEY=your-secure-hmac-key
