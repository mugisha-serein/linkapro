# Django Settings
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=False
TOKEN_ENV=development
PASSWORD_RESET_HASH_KEY=change-me-to-a-long-random-hmac-key
# Transitional compatibility for identity tokens minted before TOKEN_ENV existed; enable explicitly only during migration.
ACCEPT_LEGACY_PAYMENT_ENV_TOKENS=false

# Password recovery abuse protection
FORGOT_PASSWORD_IP_RATE=5/min
FORGOT_PASSWORD_EMAIL_RATE=3/hour
RESET_PASSWORD_IP_RATE=10/min
RESET_PASSWORD_TOKEN_RATE=5/hour
PUBLIC_VENDOR_INQUIRY_RATE=5/hour

# Login, registration, and MFA abuse protection
LOGIN_IP_RATE=10/min
LOGIN_EMAIL_RATE=5/min
LOGIN_USER_RATE=20/hour
REGISTER_IP_RATE=5/hour
REGISTER_EMAIL_DOMAIN_RATE=20/hour
TWO_FACTOR_IP_RATE=10/min
TWO_FACTOR_TEMP_TOKEN_RATE=5/min
GOOGLE_OAUTH_IP_RATE=20/min
LOGIN_FAILURE_LOCKOUT_THRESHOLD=8
LOGIN_FAILURE_LOCKOUT_SECONDS=900
MFA_FAILURE_LOCKOUT_THRESHOLD=5
MFA_FAILURE_LOCKOUT_SECONDS=900
RATE_LIMIT_HASH_KEY=
# Enable only behind a trusted proxy such as Render that controls X-Forwarded-For.
PASSWORD_RECOVERY_TRUST_X_FORWARDED_FOR=false

# Database
DB_NAME=linkapro
DB_USER=linkapro_admin
DB_PASSWORD=database-password
DB_HOST=localhost
DB_PORT=5432
ALLOWED_HOSTS=localhost,127.0.0.1
# Never point these at a production/Render host — use the local docker-compose 'db' service or a local Postgres install only.
DJANGO_DATABASE_URL=postgres://linkapro_admin:database-password@localhost:5432/linkapro
FASTAPI_DATABASE_URL=postgresql+asyncpg://linkapro_admin:database-password@localhost:5432/linkapro

TEST_DB_NAME=database-test-name
TEST_DB_USER=database-test-user
TEST_DB_PASSWORD=database-test-password
TEST_DB_HOST=localhost
TEST_DB_PORT=5432

# Redis
# Local Redis: redis://localhost:6379/0
# Production Redis/Upstash/Render may use rediss:// with TLS.
# Example: rediss://default:PASSWORD@HOST:PORT?ssl_cert_reqs=CERT_REQUIRED
# Do not wrap REDIS_URL in quotes or split it across lines.
REDIS_URL=redis://localhost:6379/0
MARKETPLACE_PROJECTION_OUTBOX_RETRY_BATCH_SIZE=25

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional ODCR/OCR document verification preflight
ODCR_ENABLED=false
ODCR_API_URL=
ODCR_API_KEY=
ODCR_TIMEOUT_SECONDS=10

# Optional professional media analyzer
VENDOR_PORTFOLIO_MAX_UPLOAD_SIZE=4194304
VENDOR_PORTFOLIO_MIN_IMAGE_WIDTH=800
VENDOR_PORTFOLIO_MIN_IMAGE_HEIGHT=600
MEDIA_ANALYZER_ENABLED=false
MEDIA_ANALYZER_API_URL=
MEDIA_ANALYZER_API_KEY=
MEDIA_ANALYZER_TIMEOUT_SECONDS=10

# Email / SendGrid SMTP
# Production must set SENDGRID_API_KEY, DEFAULT_FROM_EMAIL, and FRONTEND_URL.
SENDGRID_API_KEY=your-sendgrid-key
DEFAULT_FROM_EMAIL=no-reply@linkapro.rw
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=apikey

RESEND_API_KEY= your-resend-api-key
RESEND_FROM_EMAIL=your-resend-from-email

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Callback URL registered in Google Cloud Console (NOT the Google auth URL).
# Local: http://localhost:8000/api/django/identity/auth/google/callback/
GOOGLE_REDIRECT_URI=http://localhost:8000/api/django/identity/auth/google/callback/
FRONTEND_URL=http://localhost:3000

# Browser client access
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Flutterwave
FLW_SECRET_KEY=your_flutterwave_secret_key
FLW_SECRET_HASH=your_webhook_secret_hash
# Payment provider mode only; do not use for identity/security token validity.
PAYMENT_ENV=test

# Flutterwave Webhook Decryptor
FLW_ENCRYPTION_KEY=your_24_byte_3des_key_here

# reCAPTCHA
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# FastAPI Internal URL (for Celery tasks)
FASTAPI_INTERNAL_URL=http://localhost:8001
FASTAPI_INTERNAL_SHARED_SECRET=change-me
FASTAPI_ENV=development
FASTAPI_ALLOW_LEGACY_INTERNAL_SECRET=false
FASTAPI_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://www.linkapro.rw,https://linkapro.rw,https://linkapro.vercel.app
FASTAPI_SCHEMA_BOOTSTRAP=true
FASTAPI_MARKETPLACE_SEARCH_CACHE_TTL_SECONDS=120
FASTAPI_MARKETPLACE_SEARCH_RATE_LIMIT_REQUESTS=60
FASTAPI_MARKETPLACE_SEARCH_RATE_LIMIT_WINDOW_SECONDS=60

# Vault
VAULT_ADDR=your-localhost-vault-address
VAULT_ROLE_ID=your-role-id
VAULT_SECRET_ID=your-secret-id
VAULT_TRANSIT_KEY_NAME=your-payment-trans-it-key-name
VAULT_TOKEN_RENEWAL_MARGIN_SECONDS=60

# HMAC Key Provider
PROVIDER_REFERENCE_HMAC_KEY=your-secure-hmac-key
