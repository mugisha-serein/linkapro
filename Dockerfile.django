FROM python:3.12-alpine

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app

WORKDIR /app

# ------------------------------------------------------------
# 1. Install build dependencies (temporary)
# ------------------------------------------------------------
RUN apk add --no-cache --virtual .build-deps \
    gcc \
    musl-dev \
    python3-dev \
    postgresql-dev \
    libffi-dev \
    cairo-dev \
    pango-dev \
    gdk-pixbuf-dev

# ------------------------------------------------------------
# 2. Install runtime dependencies (kept after build)
# ------------------------------------------------------------
RUN apk add --no-cache \
    postgresql-libs \
    libffi \
    cairo \
    pango \
    gdk-pixbuf \
    shared-mime-info

# ------------------------------------------------------------
# 3. Install Python dependencies
# ------------------------------------------------------------
# Copy only requirements first (caching layer)
COPY requirements/base.txt requirements/production.txt ./

RUN pip install --upgrade pip && \
    pip install --no-cache-dir -r production.txt

# ------------------------------------------------------------
# 4. Remove build dependencies
# ------------------------------------------------------------
RUN apk del .build-deps

# ------------------------------------------------------------
# 5. Copy project source
# ------------------------------------------------------------
COPY . .

# ------------------------------------------------------------
# 6. Create non-root user and set up directories
# ------------------------------------------------------------
RUN adduser -D -u 1000 django && \
    mkdir -p /app/static /app/media && \
    chown -R django:django /app

USER django

# ------------------------------------------------------------
# 7. Default command (overridden in compose if needed)
# ------------------------------------------------------------
CMD ["gunicorn", "django_app.wsgi:application", "--bind", "0.0.0.0:8000"]